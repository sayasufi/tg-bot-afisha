# ─────────────────────────────────────────────────────────────────────────────
# App & Server
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
API_PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://afisha:afisha@postgres:5432/afisha
SYNC_DATABASE_URL=postgresql+psycopg://afisha:afisha@postgres:5432/afisha

# ─────────────────────────────────────────────────────────────────────────────
# Redis & Celery
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# LLM
# ─────────────────────────────────────────────────────────────────────────────
LLM_API_BASE_URL=http://176.109.82.96:5000
LLM_TIMEOUT_SECONDS=20

# ─────────────────────────────────────────────────────────────────────────────
# Geocoding
# ─────────────────────────────────────────────────────────────────────────────
YANDEX_GEOCODER_KEY=
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot & WebApp
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# Telethon (Telegram API)
# ─────────────────────────────────────────────────────────────────────────────
TELETHON_API_ID=0
TELETHON_API_HASH=
TELETHON_SESSION=afisha_session

# ─────────────────────────────────────────────────────────────────────────────
# External APIs
# ─────────────────────────────────────────────────────────────────────────────
TIMEPAD_BASE_URL=https://api.timepad.ru/v1

# ─────────────────────────────────────────────────────────────────────────────
# Defaults
# ─────────────────────────────────────────────────────────────────────────────
DEFAULT_CITY=Moscow
DEFAULT_COUNTRY=RU
