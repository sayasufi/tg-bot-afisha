APP_ENV=local
LOG_LEVEL=INFO
API_PORT=8000
DATABASE_URL=postgresql+psycopg://afisha:afisha@postgres:5432/afisha
SYNC_DATABASE_URL=postgresql+psycopg://afisha:afisha@postgres:5432/afisha
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
SENTRY_DSN=
# vLLM + tpro-backend on l40s (/var/www/test-llm); on the l40s server itself use http://host.docker.internal:5000
LLM_API_BASE_URL=http://109.120.182.219:5000
LLM_TIMEOUT_SECONDS=20
YANDEX_GEOCODER_KEY=
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=http://localhost:5173
# Owner-only GET /v1/stats?token= north-star readout. Leave EMPTY to keep the endpoint
# disabled (returns 404); set a long random secret to enable it.
STATS_TOKEN=
TELETHON_API_ID=0
TELETHON_API_HASH=
TELETHON_SESSION=afisha_session
DEFAULT_CITY=Moscow
DEFAULT_COUNTRY=RU
# MinIO (S3-compatible) object storage for cached event images.
# Set a strong, unique password before any non-local deployment.
MINIO_ROOT_USER=okrest
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=event-media
# Absolute base the browser uses to load cached images (prod: https://www.tgbot-afisha.ru/v1/media)
MEDIA_PUBLIC_BASE=
# Base URL of the API as seen from the miniapp user's browser (docker-compose passes it to the miniapp container)
VITE_API_BASE=http://localhost:8000
